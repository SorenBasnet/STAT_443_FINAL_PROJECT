# Example logic:
# 1. Prepare the mutation data
wide_mutations <- data_mutations %>%
# FIX: Filter for rows where Hugo_Symbol is NOT missing
filter(!is.na(Hugo_Symbol) & Hugo_Symbol != "") %>%
# Mark presence of mutation
mutate(has_mutation = 1) %>%
# Ensure one row per Sample-Gene pair to avoid pivot errors
distinct(Tumor_Sample_Barcode, Hugo_Symbol, .keep_all = TRUE) %>%
# PIVOT: Create a column for EVERY gene
pivot_wider(
names_from = Hugo_Symbol,
values_from = has_mutation,
values_fill = 0,
names_prefix = "mut_" # Optional: prefixes genes with 'mut_'
) %>%
clean_names()
